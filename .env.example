# =============================================================================
# World Cup HQ — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# =============================================================================

# ── AI (required for Ask AI feature) ────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── News API (optional — for live news feed integration) ────────────────────
# Supported providers: newsapi | sportmonks | rapidapi
# Leave blank to use the built-in seed news data
NEWS_API_KEY=
NEWS_PROVIDER=

# ── Public app config ────────────────────────────────────────────────────────
# Exposed to the browser — no secrets here
NEXT_PUBLIC_APP_NAME=World Cup HQ
